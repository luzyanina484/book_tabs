// Remove duplicates
const seen = new Set();
const UNIQUE_PL = PRICELISTS.filter(p => {
  if (seen.has(p.url)) return false;
  seen.add(p.url); return true;
});

// ============================================================
// STATE
// ============================================================
let plSortKey = 'name';
let plSortAsc = true;
let bookData = []; // [{col1, col2, ...}]
let bookHeaders = [];
let bookSource = '';
let bookQuery = '';
let activeTab = 'pricelists';
let currentLoadingUrl = null;
let currentLoadingName = '';

// ============================================================
// TABS
// ============================================================
function switchTab(tab) {
  activeTab = tab;
  document.querySelectorAll('.tab').forEach((t,i) => {
    t.classList.toggle('active', ['pricelists','book-search','upload'][i] === tab);
  });
  document.querySelectorAll('.panel').forEach((p,i) => {
    p.classList.toggle('active', ['tab-pricelists','tab-book-search','tab-upload'][i] === 'tab-'+tab);
  });
}

// ============================================================
// PRICELISTS
// ============================================================
function getExt(url) {
  return url.split('.').pop().toUpperCase().replace('XLSX','XLSX').replace('XLS','XLS').replace('DOCX','DOCX');
}

function isFresh(dateStr) {
  const d = new Date(dateStr);
  const now = new Date('2026-05-29');
  return (now - d) < 3 * 24 * 3600 * 1000;
}

function filterPricelists() {
  const q = document.getElementById('pl-search').value.toLowerCase();
  const sort = document.getElementById('pl-sort').value;
  let items = UNIQUE_PL.filter(p => p.name.toLowerCase().includes(q));
  items.sort((a,b) => {
    if (sort === 'name') return a.name.localeCompare(b.name, 'ru');
    if (sort === 'date') return b.date.localeCompare(a.date);
    return 0;
  });
  renderPricelists(items);
  document.getElementById('pl-count').textContent = items.length;
}

function sortPricelists(key) {
  if (plSortKey === key) plSortAsc = !plSortAsc;
  else { plSortKey = key; plSortAsc = true; }
  document.getElementById('pl-sort').value = key === 'date' ? 'date' : 'name';
  filterPricelists();
}

function renderPricelists(items) {
  const tbody = document.getElementById('pl-tbody');
  if (!items.length) {
    tbody.innerHTML = '<tr><td colspan="5"><div class="empty-state"><div class="icon">🔎</div><p>Ничего не найдено</p></div></td></tr>';
    return;
  }
  tbody.innerHTML = items.map(p => `
    <tr>
      <td class="publisher-name">
        ${p.special ? '<span class="special">АКЦИЯ</span>' : ''}
        ${escHtml(p.name)}
      </td>
      <td class="date-cell ${isFresh(p.date) ? 'fresh' : ''}">${p.date}</td>
      <td class="size-cell">${p.size}</td>
      <td class="date-cell">${getExt(p.url)}</td>
      <td><div class="actions-cell">
        <a class="btn-dl" href="${p.url}" download target="_blank">↓ Скачать</a>
        <button class="btn-parse" onclick="loadPricelist('${p.url}','${escJs(p.name)}')">▶ Открыть</button>
      </div></td>
    </tr>
  `).join('');
}

function escHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function escJs(s) { return s.replace(/'/g,"\\'"); }

// ============================================================
// LOAD & PARSE EXCEL
// ============================================================
async function loadPricelist(url, name) {
  currentLoadingUrl = url;
  currentLoadingName = name;
  switchTab('book-search');
  document.getElementById('book-search-empty').style.display = 'none';
  document.getElementById('book-search-ui').style.display = 'none';

  // Show loading inline
  const ui = document.getElementById('book-search-ui');
  ui.style.display = 'block';
  ui.innerHTML = `<div class="loading-bar"><div class="spinner"></div><p>Загружаем прайс: ${escHtml(name)}...</p></div>`;

  try {
    const resp = await fetch(url);
    if (!resp.ok) throw new Error('HTTP ' + resp.status);
    const ab = await resp.arrayBuffer();
    parseExcel(ab, name);
  } catch(e) {
    ui.innerHTML = `
      <div class="info-box" style="border-left-color:var(--red)">
        <h3 style="color:var(--red)">Ошибка загрузки</h3>
        <p>Не удалось загрузить файл автоматически — возможно, сервер блокирует прямые запросы из браузера (CORS).</p>
        <p style="margin-top:8px"><strong style="color:var(--text)">Решение:</strong> скачайте файл вручную и используйте вкладку «Загрузить файл».</p>
        <p style="margin-top:12px">
          <a class="btn-dl" href="${url}" download target="_blank" style="display:inline-flex;align-items:center;gap:6px;text-decoration:none">↓ Скачать ${escHtml(name)}</a>
          &nbsp;&nbsp;
          <button class="btn-parse" onclick="switchTab('upload')">📁 Перейти к загрузке</button>
        </p>
      </div>`;
  }
}

function parseExcel(arrayBuffer, name) {
  try {
    const wb = XLSX.read(arrayBuffer, {type:'array'});
    const ws = wb.Sheets[wb.SheetNames[0]];
    const rows = XLSX.utils.sheet_to_json(ws, {header:1, defval:''});
    if (!rows.length) { showNoData(name); return; }

    // Find header row (first row with most non-empty cells)
    let headerRow = 0;
    let maxFilled = 0;
    for (let i = 0; i < Math.min(10, rows.length); i++) {
      const filled = rows[i].filter(c => c !== '' && c !== null && c !== undefined).length;
      if (filled > maxFilled) { maxFilled = filled; headerRow = i; }
    }

    bookHeaders = rows[headerRow].map((h,i) => h ? String(h).trim() : `Столбец_${i+1}`);
    bookData = rows.slice(headerRow + 1)
      .filter(r => r.some(c => c !== '' && c !== null && c !== undefined))
      .map(r => {
        const obj = {};
        bookHeaders.forEach((h,i) => { obj[h] = r[i] !== undefined ? String(r[i]) : ''; });
        return obj;
      });

    bookSource = name;
    renderBookSearch();
  } catch(e) {
    document.getElementById('book-search-ui').innerHTML = `
      <div class="info-box" style="border-left-color:var(--red)">
        <h3 style="color:var(--red)">Ошибка чтения файла</h3>
        <p>${escHtml(e.message)}</p>
      </div>`;
  }
}

function showNoData(name) {
  document.getElementById('book-search-ui').innerHTML = `
    <div class="info-box" style="border-left-color:var(--red)">
      <h3>Нет данных</h3><p>Файл «${escHtml(name)}» пустой или не удалось прочитать.</p>
    </div>`;
}

function renderBookSearch() {
  const ui = document.getElementById('book-search-ui');
  ui.style.display = 'block';

  // Build col filter options
  const colOpts = bookHeaders.map(h => `<option value="${escHtml(h)}">${escHtml(h)}</option>`).join('');

  ui.innerHTML = `
    <div class="book-panel-header">
      <button class="back-btn" onclick="switchTab('pricelists')">← Назад</button>
      <h2>${escHtml(bookSource)}</h2>
    </div>
    <div class="source-info">
      <strong>${bookData.length}</strong> строк · <strong>${bookHeaders.length}</strong> столбцов ·
      Столбцы: ${bookHeaders.slice(0,8).map(h=>`<em>${escHtml(h)}</em>`).join(', ')}${bookHeaders.length>8?'…':''}
    </div>
    <div class="book-search-row">
      <div class="search-wrap">
        <span class="search-icon">🔍</span>
        <input type="text" id="bs-query" placeholder="Введите название, автора, ISBN, серию..." oninput="searchBooks()" autofocus>
      </div>
      <select class="filter-select" id="bs-col-filter" onchange="searchBooks()">
        <option value="">Все столбцы</option>
        ${colOpts}
      </select>
    </div>
    <div class="rows-info" id="bs-rows-info">Введите запрос для поиска, или оставьте пустым — покажем первые 50 строк</div>
    <div id="bs-results"></div>
  `;

  searchBooks();
}

function searchBooks() {
  const q = (document.getElementById('bs-query')?.value || '').toLowerCase().trim();
  const col = document.getElementById('bs-col-filter')?.value || '';
  const info = document.getElementById('bs-rows-info');
  const results = document.getElementById('bs-results');
  if (!bookData.length) return;

  let filtered;
  if (!q) {
    filtered = bookData.slice(0, 50);
  } else {
    filtered = bookData.filter(row => {
      if (col) return (row[col] || '').toLowerCase().includes(q);
      return Object.values(row).some(v => v.toLowerCase().includes(q));
    });
  }

  if (info) info.textContent = q
    ? `Найдено: ${filtered.length} из ${bookData.length} строк`
    : `Показаны первые 50 из ${bookData.length} строк`;

  if (!filtered.length) {
    results.innerHTML = '<div class="empty-state"><div class="icon">📭</div><p>Ничего не найдено по запросу «'+escHtml(q)+'»</p></div>';
    return;
  }

  // Find likely price / name / author columns
  const priceCols = bookHeaders.filter(h => /цен|price|руб|стоим/i.test(h));
  const nameCols = bookHeaders.filter(h => /назв|title|наим|книг|товар/i.test(h));
  const authorCols = bookHeaders.filter(h => /автор|author/i.test(h));
  const isbnCols = bookHeaders.filter(h => /isbn|арт|код/i.test(h));
  const otherCols = bookHeaders.filter(h => !priceCols.includes(h) && !nameCols.includes(h) && !authorCols.includes(h) && !isbnCols.includes(h));

  const displayRows = filtered.slice(0, 100);
  results.innerHTML = `<div class="books-grid">${displayRows.map(row => {
    const title = nameCols.map(c=>row[c]).filter(Boolean).join(' · ') || Object.values(row).find(v=>v.length>5) || '—';
    const author = authorCols.map(c=>row[c]).filter(Boolean).join(', ');
    const price = priceCols.map(c=>row[c]).filter(Boolean).join(' / ');
    const isbn = isbnCols.map(c=>row[c]).filter(Boolean).join(' ');
    const extra = otherCols.slice(0,5).filter(c=>row[c]).map(c=>`<span>📌 ${escHtml(c)}: ${escHtml(row[c])}</span>`).join('');
    return `<div class="book-card">
      <div class="book-title">${escHtml(title)}</div>
      <div class="book-meta">
        ${author ? `<span>✍️ ${escHtml(author)}</span>` : ''}
        ${isbn ? `<span>🔢 ${escHtml(isbn)}</span>` : ''}
        ${extra}
      </div>
      ${price ? `<div class="book-price">${escHtml(price)} ₽</div>` : ''}
    </div>`;
  }).join('')}</div>
  ${filtered.length > 100 ? `<p style="text-align:center;font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--muted);margin-top:16px">Показано 100 из ${filtered.length}. Уточните запрос.</p>` : ''}`;
}

// ============================================================
// FILE UPLOAD
// ============================================================
function handleFileInput(e) {
  const file = e.target.files[0];
  if (file) processFile(file);
}

function handleDrop(e) {
  e.preventDefault();
  document.getElementById('upload-zone').classList.remove('drag');
  const file = e.dataTransfer.files[0];
  if (file) processFile(file);
}

function processFile(file) {
  document.getElementById('upload-loading').style.display = 'block';
  document.getElementById('upload-zone').style.display = 'none';
  const reader = new FileReader();
  reader.onload = (e) => {
    document.getElementById('upload-loading').style.display = 'none';
    document.getElementById('upload-zone').style.display = 'block';
    parseExcel(e.target.result, file.name);
    switchTab('book-search');
    document.getElementById('book-search-ui').style.display = 'block';
    document.getElementById('book-search-empty').style.display = 'none';
  };
  reader.onerror = () => {
    document.getElementById('upload-loading').style.display = 'none';
    document.getElementById('upload-zone').style.display = 'block';
    alert('Ошибка чтения файла');
  };
  reader.readAsArrayBuffer(file);
}

// ============================================================
// INIT
// ============================================================
filterPricelists();
</script>
